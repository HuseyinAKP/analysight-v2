# Analysight API — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyala: cp .env.example .env

# ── Claude AI (Anthropic) ─────────────────────────────────────────────
# TradingView alertlerini, sabah brifingini ve analist analizini Claude AI ile güçlendirir.
# https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Twitter / X API ───────────────────────────────────────────────────
# Sosyal sinyal verisi için X API v2 Bearer Token.
# https://developer.twitter.com/en/portal/dashboard
X_BEARER_TOKEN=AAAA...

# ── Telegram Bot (opsiyonel) ──────────────────────────────────────────
# TradingView alertlerini Telegram'a ilet.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
